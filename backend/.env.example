# ==================================
# CCP-Backend Environment Variables
# ==================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ==================================
# Flask Configuration
# ==================================
FLASK_ENV=development
DEBUG=True
SECRET_KEY=your-super-secret-key-change-me-in-production
FLASK_SECRET_KEY=another-secret-key-for-sessions

# ==================================
# Database (PostgreSQL)
# ==================================
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=ccpay_db
DB_PORT=5432
DB_SSLMODE=prefer

# ==================================
# JWT Authentication
# ==================================
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=86400

# ==================================
# Redis (Cache & Sessions)
# ==================================
REDIS_URL=redis://localhost:6379/0
REDIS_FALLBACK_URL=redis://localhost:6379/1
SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0

# ==================================
# Cloudinary (Image/File Storage)
# ==================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=community_posts

# ==================================
# Firebase (Push Notifications)
# ==================================
FIREBASE_CREDENTIALS=/secrets/firebase_credentials.json

# ==================================
# Typesense (Search Engine)
# ==================================
# Development
TYPESENSE_API_KEY=xyz_local_dev_key
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_HOST=localhost

# Production
TYPESENSE_PROD_API_KEY=your_production_typesense_key
TYPESENSE_PROD_HOST=typesense.yourdomain.com
TYPESENSE_PROD_PORT=443
TYPESENSE_PROD_PROTOCOL=https

# ==================================
# Email (SMTP)
# ==================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_NAME=CCPay <noreply@ccpay.ng>
DEFAULT_FROM_EMAIL=noreply@ccpay.ng

# ==================================
# External API Services
# ==================================

# IDCheck.ng (Verification)
IDCHECK_API_KEY=your_idcheck_api_key

# Bell MFB (Payment Provider)
BELL_MFB_CLIENT_ID=your_bell_client_id
BELL_MFB_CLIENT_SECRET=your_bell_client_secret
BELL_MFB_BASE_URL=https://api-sandbox.bellmfb.com/v1
BELL_MFB_BUSINESS_ACCOUNT=your_business_account_number
BELL_MFB_WEBHOOK_SECRET=your_webhook_secret

# ==================================
# OAuth Providers
# ==================================

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=your.apple.client.id
APPLE_TEAM_ID=YOUR_TEAM_ID
APPLE_KEY_ID=YOUR_KEY_ID
APPLE_PRIVATE_KEY_PATH=/path/to/apple_private_key.p8
APPLE_REDIRECT_URI=http://localhost:8080/api/auth/apple/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_REDIRECT_URI=http://localhost:8080/api/auth/facebook/callback

# ==================================
# Session Configuration
# ==================================
SESSION_TYPE=redis
SESSION_PERMANENT=True
SESSION_USE_SIGNER=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME=604800

# ==================================
# Application Settings
# ==================================
PORT=8080
MESSAGES_PER_PAGE=20
ENV=development

# ==================================
# Feature Flags (Migration Support)
# ==================================
USE_NEW_USER_SERVICE=false
USE_NEW_AUTH_SERVICE=false
USE_NEW_WALLET_SERVICE=false
USE_NEW_COMMUNITY_SERVICE=false
USE_NEW_NOTIFICATION_SERVICE=false
SHADOW_MODE=false
NEW_CODE_PERCENTAGE=0

# ==================================
# Monitoring & Logging
# ==================================
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_if_using

# ==================================
# Frontend URLs (CORS)
# ==================================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://ccpay.ng
